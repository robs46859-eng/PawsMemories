# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted (production: https://pawsome3d.com).
# Used for self-referential links and Stripe checkout success/cancel redirects.
APP_URL="https://pawsome3d.com"

# STRIPE_SECRET_KEY: Required for communicating with Stripe API.
# Obtain from your Stripe Dashboard (Developers > API keys). Starts with sk_test_ or sk_live_.
STRIPE_SECRET_KEY="MY_STRIPE_SECRET_KEY"

# STRIPE_WEBHOOK_SECRET: Required for verifying Stripe webhook authenticity. Starts with whsec_.
# This is the signing secret for the Stripe webhook endpoint, which must point at
# https://pawsome3d.com/api/stripe-webhook and listen to checkout.session.completed +
# checkout.session.async_payment_succeeded. Editing an existing endpoint's URL keeps
# the same secret; creating a NEW endpoint issues a new secret you must paste here.
STRIPE_WEBHOOK_SECRET="MY_STRIPE_WEBHOOK_SECRET"

# --- Authentication (email + password) ---
# Secret used to sign session JWTs. Use a long random string in production.
JWT_SECRET="MY_JWT_SECRET"

# Admin account — server upserts this on every boot. Admins log in through the
# normal login screen using ADMIN_EMAIL + ADMIN_PASSWORD.
# ADMIN_KEY is just an internal unique row key (any short string, e.g. "admin");
# it is NOT a phone number.
ADMIN_KEY="admin"
ADMIN_EMAIL="your@email.com"
ADMIN_PASSWORD="choose-a-strong-password"

# --- MySQL database (user store / gating) ---
# On Hostinger, use 127.0.0.1 (NOT "localhost") so mysql2 connects over IPv4 and
# matches the database user's grant. DB_PORT defaults to 3306 if omitted.
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_NAME="MY_DB_NAME"
DB_USER="MY_DB_USER"
DB_PASSWORD="MY_DB_PASSWORD"

# --- Google Maps Platform ---
# CRITICAL: Create TWO separate API keys in Google Cloud Console.
# 1. SERVER key: used server-side for Street View metadata/images, Places text search
#    (landmarks), and the Community page's nearby parks (Places Nearby Search) + weather
#    (Weather API). Must NOT have an HTTP-referrer restriction (server calls have no
#    referrer) — leave unrestricted or restrict by your Hostinger server IP.
#    Enable these APIs on this key: Street View Static API, Places API, Weather API.
# 2. BROWSER key: Restrict by HTTP Referrer (e.g., https://pawsome3d.com/*,
#    https://www.pawsome3d.com/*, http://localhost:3000/*) and APIs: Maps JavaScript API,
#    Places API. This is a VITE_ var and is baked into the frontend at BUILD time, so it
#    must be present when `npm run build` runs. NEVER expose the SERVER key to the frontend.
GOOGLE_MAPS_API_KEY_SERVER="YOUR_SERVER_RESTRICTED_KEY"

# Frontend Vite environment variable (must be prefixed with VITE_)
VITE_GOOGLE_MAPS_API_KEY_BROWSER="YOUR_BROWSER_RESTRICTED_KEY"

# --- Community page: no keys required ---
# Pet recall news uses the free openFDA enforcement API; the live pet board uses the
# free public dog.ceo + dogapi.dog APIs; weather falls back to free open-meteo if the
# Google Weather API isn't enabled. User photo uploads reuse the MEDIA_BUCKET_* storage.

# --- Object Storage (Phase 2+) ---
# Required for storing generated videos and large still images (avoids base64/DB bloat).
# Supports Hostinger Object Storage, AWS S3, or Backblaze B2.
MEDIA_BUCKET_NAME="pawsmemories-media"
MEDIA_BUCKET_URL="https://s3.us-east-005.backblazeb2.com"
MEDIA_BUCKET_KEY="YOUR_ACCESS_KEY"
MEDIA_BUCKET_SECRET="YOUR_SECRET_KEY"

# --- 3D Generation (Tripo3D) ---
# REQUIRED for image-to-3D + auto-rig. Without it, avatar/model generation fails.
# Obtain from https://platform.tripo3d.ai (API keys).
TRIPO_API_KEY="YOUR_TRIPO_API_KEY"

# --- Blender Worker Microservice ---
# URL of the Blender worker running on Render (Docker container with Blender CLI).
# Supports /render, /rig-model, and /bake-sprites endpoints.
# WORKER_SHARED_SECRET must be IDENTICAL here and in the Render worker's env
# (sent as the x-worker-secret header). A mismatch = every worker call 401s.
BLENDER_WORKER_URL="https://pawsmemories.onrender.com/render"
WORKER_SHARED_SECRET="YOUR_WORKER_SHARED_SECRET"

# --- AR Virtual Pet Simulator (AR_PET_SIM_SPEC) ---
# Feature flag for the Tripo auto-rig pipeline (POST /api/pets/:id/rig). Off by
# default so avatars without a rig keep the current render path.
PETSIM_RIG_ENABLED="false"
# Optional: pin the Tripo rig model version (defaults to v2.0-20250506 in code).
TRIPO_RIG_MODEL_VERSION="v2.0-20250506"

# Paid-endpoint hardening (H2/H7) for classify, rig, and semantic-scan.
# Kill-switches — return 503 when off. Omit/leave blank to use defaults.
#   Master switch for all three paid endpoints (default: on).
PETSIM_PAID_APIS_ENABLED="true"
#   Per-endpoint switches (classify + semantic-scan default on; rig uses
#   PETSIM_RIG_ENABLED above, default off).
PETSIM_CLASSIFY_ENABLED="true"
PETSIM_SEMANTIC_SCAN_ENABLED="true"
# Per-user, per-day caps — requests past the cap return 429. Defaults in code:
# classify 25, rig 5, semantic-scan 50. Set to 0 to hard-disable via the cap.
PETSIM_CLASSIFY_DAILY_CAP="25"
PETSIM_RIG_DAILY_CAP="5"
PETSIM_SEMANTIC_SCAN_DAILY_CAP="50"
# Per-user request-rate limit is fixed at 20/min/user across these endpoints.

# --- Multi-Agent Avatar Builder ---
# The new multi-agent pipeline uses Gemini (Vision), Claude (Reasoning), and GPT (Code Gen)
GEMINI_API_KEY="MY_GEMINI_API_KEY" # (Duplicate of above, or use the same one)

# --- HeyGen API (Talking Pets) ---
HEYGEN_API_KEY="YOUR_HEYGEN_API_KEY"
HEYGEN_DEFAULT_VOICE_ID="YOUR_HEYGEN_DEFAULT_VOICE_ID"

# --- Twilio SMS Notifications ---
# Optional. Used to text users when an admin fulfills a memory request. If blank,
# fulfillment still works — the SMS step is skipped.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
# Optional legacy Verify service (SMS "from" fallback in some notification paths).
TWILIO_VERIFY_SERVICE_SID=""

# =====================================================================
#  Runtime / server (mostly optional — sane defaults in code)
# =====================================================================
# Port the Node server listens on. Defaults to 3000. Hostinger usually sets this
# for you via its Node app manager — only set if you need a specific port.
PORT="3000"
# Set to "production" in prod. The server also auto-detects prod when dist/index.html
# exists, so this is belt-and-suspenders.
NODE_ENV="production"
# Optional CORS allow-list (comma-separated origins). If unset, same-origin only.
# e.g. "https://pawsome3d.com,https://www.pawsome3d.com"
ALLOWED_ORIGINS=""
# Optional alternative to the DB_* vars: a single MySQL connection string.
# If DB_HOST/DB_NAME/DB_USER are set (above), you do NOT need this.
DATABASE_URL=""

# =====================================================================
#  Gemini model overrides (optional)
# =====================================================================
# Comma-separated image-model fallback chain. Defaults in code:
#   gemini-3-pro-image,gemini-3.1-flash-image,gemini-2.5-flash-image
GEMINI_IMAGE_MODELS=""
# Optional text-model fallback override.
GEMINI_TEXT_FALLBACK_MODEL=""

# =====================================================================
#  Animator / Scenes worker (optional — defaults in code)
# =====================================================================
# Where animator working files live. Defaults to ./data/animator.
ANIMATOR_DATA_DIR=""
# Set to "false" to disable the background animator job worker. Default: enabled.
ANIMATOR_WORKER_ENABLED="true"
# Worker tuning (optional): parallelism and how long before a job is stale.
ANIMATOR_WORKER_CONCURRENCY=""
ANIMATOR_STALE_MS=""

# =====================================================================
#  OpenAI-compatible LLM for the multi-agent Blender pipeline (optional)
# =====================================================================
# Only needed if the multi-agent code-gen pipeline uses an OpenAI-compatible
# endpoint (e.g. OpenRouter). Leave blank to rely on Gemini/Ollama paths.
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_HTTP_REFERER=""
OPENAI_X_TITLE=""

# Note: ADMIN_PHONE is an accepted alias for ADMIN_KEY (either works as the
# internal admin row key). VITE_* vars are baked in at BUILD time, so they must
# be present when `npm run build` runs — not just at server start.

# =====================================================================
#  Phase 9 — model cap & domain mode (per-site)
# =====================================================================
# Max models a non-admin user may keep (hard cap on pawsome3d.com). Default 5.
MODEL_CAP="5"
# Which experience this deployment serves. Set per Hostinger site:
#   main       → pawsome3d.com (full app + 5-model cap)  [default]
#   warehouse  → mypets.cc ("cold storage" viewer/manager — future phase)
DEPLOY_TARGET="main"
# Where 3D-print request emails are addressed (the "Avatars-R-Us" print form).
# Falls back to ADMIN_EMAIL if unset. Shown to logged-in users' mail client only.
PRINT_REQUEST_EMAIL=""
