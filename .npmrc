# @theatre/r3f@0.7.x still peer-depends on @react-three/fiber@^8, but this project
# runs Fiber v9 (required for React 19). npm 7+ errors on that peer mismatch
# (ERESOLVE). legacy-peer-deps makes install deterministic instead of relying on
# the host's auto-retry. NOTE: the Theatre pro-mode timeline (@theatre/r3f) is not
# verified on Fiber v9 — keep it flag-gated until migrated to @theatre/core +
# @theatre/studio (imperative, no R3F peer). See docs/PHASE8_AGENT_PROMPT.md.
legacy-peer-deps=true
