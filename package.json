{
  "name": "paws-and-memories",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:full": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "tsx --test tests/*.test.mjs",
    "test:brain": "tsx --test tests/brain_*.test.mjs",
    "test:pets": "tsx --test tests/pets_*.test.mjs",
    "test:ar": "tsx --test tests/brain_*.test.mjs tests/pets_*.test.mjs tests/ar_*.test.mjs tests/paid_guards.test.mjs",
    "animator:doctor": "node scripts/animator-doctor.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@gltf-transform/cli": "^4.4.1",
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@google/genai": "^2.4.0",
    "@gradio/client": "^2.3.0",
    "@react-google-maps/api": "^2.20.8",
    "@react-three/drei": "^10.0.6",
    "@react-three/fiber": "^9.1.0",
    "@react-three/xr": "^6.6.9",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "form-data": "^4.0.6",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mp4-muxer": "^5.2.2",
    "mysql2": "^3.11.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sharp": "^0.35.3",
    "stripe": "^22.2.0",
    "tailwindcss": "^4.1.14",
    "three": "^0.171.0",
    "twilio": "^6.0.2",
    "typescript": "~5.8.2",
    "uuid": "^14.0.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/form-data": "^2.2.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.171.0",
    "tsx": "^4.21.0"
  }
}
